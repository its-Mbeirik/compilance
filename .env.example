# Database
POSTGRES_USER=conformite
POSTGRES_PASSWORD=conformite_secret
POSTGRES_DB=conformite_db
DATABASE_URL=postgresql://conformite:conformite_secret@localhost:5433/conformite_db

# Redis
REDIS_URL=redis://localhost:6379

# LLM — choisir l'un ou l'autre
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# LLM routing (claude-sonnet-4-5 ou gpt-4o pour vérification, gpt-4o-mini pour récupération)
VERIFIER_MODEL=claude-sonnet-4-5
EXTRACTOR_MODEL=claude-sonnet-4-5

# Embeddings (local, aucun coût API)
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# App
BACKEND_CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
